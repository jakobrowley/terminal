# Windows makefile for terminal-listener

# Compiler settings
CXX = cl
CXXFLAGS = /EHsc /Fe:terminal-listener.exe
LIBS = user32.lib

# Target executable
TARGET = terminal-listener.exe
SRC = KeyboardListenerWin.cpp

.PHONY: all clean

all: $(TARGET)

$(TARGET): $(SRC)
	$(CXX) $(CXXFLAGS) $(SRC) $(LIBS)

clean:
	-del $(TARGET) 2>NUL 